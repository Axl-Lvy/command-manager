<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Read logging.file.path and logging.max-history from Spring config -->
  <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>
  <springProperty scope="context" name="MAX_HISTORY" source="logging.max-history" defaultValue="7"/>

  <!-- Console appender — always available -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      <charset>${CONSOLE_LOG_CHARSET}</charset>
    </encoder>
  </appender>

  <!-- Rolling file appender — activated by profiles that need file logging -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/command-manager.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/command-manager.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>${MAX_HISTORY}</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>${FILE_LOG_PATTERN}</pattern>
      <charset>${FILE_LOG_CHARSET}</charset>
    </encoder>
  </appender>

  <!-- Suppress noisy Atmosphere logs -->
  <logger name="org.atmosphere" level="WARN"/>

  <!-- local / default: console only, INFO -->
  <springProfile name="local | default">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <!-- prod: console + file, INFO -->
  <springProfile name="prod">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
    </root>
  </springProfile>

  <!-- test: console + file, DEBUG -->
  <springProfile name="test">
    <root level="DEBUG">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
    </root>
  </springProfile>

</configuration>
